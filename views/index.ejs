<!DOCTYPE html>
<html lang="en" data-bs-theme="auto">
  <head>
    <script src="./js/color-modes.js"></script>
    <link
      rel="stylesheet"
      href="./bootstrap-icons-1.10.5/font/bootstrap-icons.min.css"
    />
    <link rel="shortcut icon" href="/mazen-logo.png" type="image/png" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="" />
    <meta
      name="author"
      content="Mark Otto, Jacob Thornton, and Bootstrap contributors"
    />
    <meta name="generator" content="Hugo 0.112.5" />
    <title>Home page</title>

    <link href="./css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="./css/dark-light.css" />

    <!-- Custom styles for this template -->
    <link href="./css/sidebars.css" rel="stylesheet" />
    <link rel="stylesheet" href="./css/myStyle.css" />
  </head>
  <body>
    <%- include('./Components/dark-light.ejs') %>

    <main class="d-flex flex-nowrap">
      <%- include('./Components/sidebar.ejs', {currentPage: "index"}) %>

      <section class="w-100 app-content">
        <%- include('./Components/navbar.ejs') %>

        <h1 id="emptyStateMessage" class="text-center mt-5 empty-state-title <%= arr.length === 0 ? '' : 'd-none' %>">
          No data available
        </h1>



          <table id="customersTable" class="text-center mx-auto table mt-4 table-striped table-bordered app-table <%= arr.length === 0 ? 'd-none' : '' %>">
          <thead>
            <tr>
              <th scope="col">#</th>
              <th scope="col">Full Name</th>
              <th scope="col">Gender</th>
              <th scope="col">Country</th>
              <th scope="col">Age</th>
              <th scope="col">Last updated</th>
              <th scope="col">Action</th>
            </tr>
          </thead>

          <tbody id="customersTableBody" data-is-viewer="<%= isViewer ? '1' : '0' %>">
            <% arr.forEach((item, index) => { %>
            <tr>
              <th scope="row"><%= index +1 %></th>
              <td><%= item.fireName %> <%= item.lastName %></td>
              <td><%= item.gender %></td>
              <td><%= item.country %></td>
              <td><%= item.age %></td>
              <td><%= moment(item.updatedAt).fromNow(); %></td>
              <td>
                <a
                  data-bs-toggle="tooltip"
                  data-bs-title="View details"
                  data-bs-placement="top"
                  class="btn btn-primary btn-sm"
                  href="/view/<%= item._id %>"
                  ><i class="bi bi-eye"></i
                ></a>

                <% if (!isViewer) { %>
                <a
                  data-bs-toggle="tooltip"
                  data-bs-title="Edit user"
                  data-bs-placement="top"
                  class="btn btn-primary btn-sm"
                  href="./edit/<%= item._id %>"
                >
                  <i class="bi bi-pencil"></i>
                </a>
                <form
                style="display: inline;"
                  action="/edit/<%= item._id %>?_method=DELETE"
                  method="post"
                >
                  <button
                    data-bs-toggle="tooltip"
                    data-bs-title="Delete user"
                    data-bs-placement="top"
                    class="btn btn-danger btn-sm"
                  >
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>


      
      </section>
    </main>
    <script src="./js/bootstrap.bundle.min.js"></script>

    <script src="./js/sidebars.js"></script>

    <script src="./js/main.js"></script>
  </body>
</html>
