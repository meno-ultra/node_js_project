<div
        id="sidebarId"
        class="position-relative d-flex flex-column flex-shrink-0 p-3 sidebar app-sidebar"
      >
        <span style="right: 10px; top: 2px" class="position-absolute">
          <button class="btn" onclick="toggleSidebar()">
            <i  class="bi bi-x-circle"></i>
          </button>
        </span>

        <a
          href="/"
          class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none"
        >
          <i class="bi bi-lightning-charge"></i>
          <span class="fs-4 sidebar-text">Sidebar</span>
        </a>
        <hr />
        <ul class="nav nav-pills flex-column mb-auto">
          <li class="nav-item">
            <a href="/" class="nav-link <%= currentPage === "index" ? "active" : null %>" aria-current="page">
              <svg class="bi pe-none me-2" width="16" height="16">
                <use xlink:href="#home" />
              </svg>
              <span class="sidebar-text"> Home </span>
            </a>
          </li>

          <% if (!isViewer) { %>
            <li>
              <a href="../user/add.html" class="nav-link <%= currentPage === "add" ? "active" : null %>">
                <svg class="bi pe-none me-2" width="16" height="16">
                  <use xlink:href="#people-circle" />
                </svg>
                <span class="sidebar-text"> Add Customers </span>
              </a>
            </li>
          <% } %>

          <li>
            <a href="/settings" class="nav-link <%= currentPage === "settings" ? "active" : null %>">
              <i class="bi bi-sliders2 me-2"></i>
              <span class="sidebar-text"> Settings </span>
            </a>
          </li>

          <li>
            <a href="/profile" class="nav-link <%= currentPage === "profile" ? "active" : null %>">
              <i class="bi bi-person-gear me-2"></i>
              <span class="sidebar-text"> Admin Profile </span>
            </a>
          </li>
        </ul>
        <hr />
        <div class="dropdown">
          <a
            href="#"
            class="d-flex align-items-center text-white text-decoration-none dropdown-toggle"
            data-bs-toggle="dropdown"
            aria-expanded="false"
          >
            <img
              src="/mazen-logo.png"
              alt="Mazen logo"
              width="32"
              height="32"
              class="rounded-circle"
            />
          </a>
          <ul class="dropdown-menu dropdown-menu-dark text-small shadow">
            <li><a class="dropdown-item" href="/settings">Settings</a></li>
            <li><a class="dropdown-item" href="/profile">Profile</a></li>
            <li><hr class="dropdown-divider" /></li>
            <li><a class="dropdown-item" href="/logout">Sign out</a></li>
          </ul>
        </div>
      </div>

      <div class="b-example-divider b-example-vr"></div>